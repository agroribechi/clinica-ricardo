      {
        "parameters": {
          "jsCode": "// Feedback customizado baseado no tipo de cliente\nconst isExistingClient = $input.first().json && $input.first().json.length > 0;\nconst clientName = isExistingClient ? $input.first().json[0]?.name : 'visitante';\nconst feedback = isExistingClient \n  ? `✨ Olá novamente, ${clientName}! A Dra. Maria Martha está analisando sua mensagem...`\n  : `👋 Bem-vindo! Sou a Cuca, assistente jurídica. A Dra. Maria Martha está analisando sua mensagem...`;\n\nreturn {\n  json: {\n    ...JSON.parse(JSON.stringify($input.first().json)),\n    feedback: feedback,\n    isExistingClient: isExistingClient\n  }\n};"
