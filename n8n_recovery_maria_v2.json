      {
        "parameters": {
          "jsCode": "const payload = $input.first().json?.body?.payload || {};\n\n// Isola a busca da chave\nconst keyData = payload._data?.key || payload.data?.key || {};\nconst jidFull = keyData.remoteJidAlt || null;\n\n// Extrai e limpa os dados\n// O /^55/ garante que o 55 só será cortado se for o começo absoluto do número\nconst jidClean = jidFull ? jidFull.replace(/@s\\.whatsapp\\.net$/, '').replace(/^55/, '') : 'ERRO';\nconst jidOnlyNum = jidFull ? jidFull.replace(/\\D/g, '').replace(/^55/, '') : 'ERRO';\n\nreturn [{\n  json: {\n    debug: {\n      jidFull: jidFull || 'NÃO ENCONTRADO',\n      jidClean: jidClean,\n      jidOnlyNum: jidOnlyNum,\n      payloadPath: payload._data ? '_data' : (payload.data ? 'data' : 'indefinido')\n    }\n  }\n}];"
        },
        "type": "n8n-nodes-base.code",
